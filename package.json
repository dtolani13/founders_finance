{
  "name": "founders-finance-workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.cjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:web": "pnpm --filter @workspace/founders-finance run dev",
    "app:start": "pnpm --filter @workspace/scripts run local-app start",
    "app:stop": "pnpm --filter @workspace/scripts run local-app stop",
    "app:restart": "pnpm --filter @workspace/scripts run local-app restart",
    "app:status": "pnpm --filter @workspace/scripts run local-app status",
    "app:doctor": "pnpm --filter @workspace/scripts run local-app doctor",
    "db:generate": "pnpm --filter @workspace/db run generate",
    "db:migrate": "pnpm --filter @workspace/db run migrate",
    "db:migrate:status": "pnpm --filter @workspace/db run migrate:status",
    "db:migrate:baseline": "pnpm --filter @workspace/db run migrate:baseline",
    "db:migrate:acceptance": "pnpm --filter @workspace/scripts run migration:acceptance",
    "backup": "pnpm --filter @workspace/scripts run backup",
    "backup:verify": "pnpm --filter @workspace/scripts run backup:verify",
    "backup:acceptance": "pnpm --filter @workspace/scripts run backup:acceptance",
    "recovery:drill": "pnpm --filter @workspace/scripts run verify-restore",
    "verify-restore": "pnpm --filter @workspace/scripts run verify-restore",
    "test": "tsx --test artifacts/api-server/src/lib/auth.test.ts artifacts/api-server/src/services/accounting.test.ts artifacts/api-server/src/services/evidence-storage.test.ts artifacts/api-server/src/services/exports.test.ts artifacts/api-server/src/services/mutation-audit.test.ts artifacts/api-server/src/services/statement-import.test.ts lib/backup/src/index.test.ts"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1",
    "tsx": "catalog:"
  }
}
