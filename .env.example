# ============================================================
# Founders Finance — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# PostgreSQL connection string (required)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5432/founders_finance

# Express session secret — use a long random string (required)
# Generate with: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_use_openssl_rand_hex_64

# Root paths for private evidence and encrypted backups.
# The launcher creates these writable directories when needed.
EVIDENCE_STORAGE_ROOT=./evidence
BACKUP_STORAGE_ROOT=./backups
# Optional: directory containing pg_dump and pg_restore when they are not on PATH.
# POSTGRES_BIN=C:\Program Files\PostgreSQL\16\bin

# Optional launcher port overrides. Defaults: API 8081, web 5175.
# API_PORT=8081
# WEB_PORT=5175
